# server4home Rancher Manager first-boot config
#
# Drop a populated copy at /etc/server4home/rancher.conf BEFORE first boot
# to override the bake-time defaults. All keys are optional.
#
# Bake-time defaults (matched to the support matrix for Rancher v2.14.1):
#
#   RANCHER_CHART_VERSION="2.14.1"
#   CERT_MANAGER_VERSION="v1.18.6"
#   RANCHER_BOOTSTRAP_PASSWORD="admin"
#   RANCHER_HOSTNAME=<system hostname at first boot>
#   RANCHER_REPLICAS="1"

# UI hostname — what users hit in the browser. Must be DNS-resolvable on your
# LAN (or you'll get TLS warnings). Defaults to the VM's hostname.
#RANCHER_HOSTNAME=rancher.lan.example.com

# Initial admin password (shown only the first time you log in; you'll set a
# permanent one via the UI immediately after). Change this for any non-toy use.
#RANCHER_BOOTSTRAP_PASSWORD=changeme

# Pin specific versions if you want to override what the image was built with.
#RANCHER_CHART_VERSION=2.14.1
#CERT_MANAGER_VERSION=v1.18.6

# Increase if running on an HA control-plane (you'd want 3 typically).
#RANCHER_REPLICAS=3
