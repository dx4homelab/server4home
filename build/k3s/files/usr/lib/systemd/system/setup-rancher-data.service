[Unit]
Description=server4home: prepare /var/lib/rancher LVM data volume
Documentation=https://github.com/dx4homelab/server4home
After=local-fs.target
Before=k3s.service
ConditionPathExists=/usr/libexec/server4home/setup-rancher-data.sh

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStart=/usr/libexec/server4home/setup-rancher-data.sh

[Install]
WantedBy=multi-user.target
